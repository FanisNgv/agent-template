{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      mistral_api_key: { type: "string", secret: true },
    },
    required: ["mistral_api_key"],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    // TODO: Replace <your-username> with your GitHub username after first push
    image: "ghcr.io/fanisngv/agent-template:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9010",

    env: {
      MISTRAL_API_KEY: "${config.mistral_api_key}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
